# Copy to .env and uncomment ONE section below.

# --- Local dev (laptop) ---
# ARK_ROLE=dev
# ARK_HOST=0.0.0.0
# ARK_PORT=8000
# ARK_DATA_DIR=./data
# ARK_SOURCE_DIR=./data/sources
# ARK_WORKSPACE_DIR=./data/workspace
# ARK_INDEX_DIR=./indexes
# ARK_INDEX_BACKEND=simple
# ARK_CHROMA_DIR=./indexes/chroma
# ARK_COLLECTION_NAME=wiki_minilm_l6_v2
# ARK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# ARK_LLM_BACKEND=mock
# ARK_LLM_MODEL=local
# ARK_LLM_TIMEOUT_SECONDS=30
# ARK_LLM_MAX_TOKENS=512
# ARK_LLM_TEMPERATURE=0.0
# ARK_MAX_IMPORT_BYTES=52428800
# ARK_LLM_BASE_URL=http://127.0.0.1:8080
# ARK_DISTANCE_THRESHOLD=0.5
# ARK_LLAMA_HOST=0.0.0.0
# ARK_LLAMA_PORT=8080
# ARK_MODEL_DIR=./models
# ARK_MODEL_PATH=./models/model.gguf
# ARK_CONTEXT_SIZE=4096
# ARK_THREADS=4

# --- RAG Pi ---
# ARK_ROLE=rag
# ARK_HOST=0.0.0.0
# ARK_PORT=8000
# ARK_DATA_DIR=/srv/ark-pi/data
# ARK_SOURCE_DIR=/srv/ark-pi/data/sources
# ARK_WORKSPACE_DIR=/srv/ark-pi/data/workspace
# ARK_INDEX_DIR=/srv/ark-pi/indexes
# ARK_INDEX_BACKEND=chroma
# ARK_CHROMA_DIR=/srv/ark-pi/indexes/chroma
# ARK_COLLECTION_NAME=wiki_minilm_l6_v2
# ARK_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# ARK_LLM_BACKEND=openai-compatible
# ARK_LLM_MODEL=local
# ARK_LLM_TIMEOUT_SECONDS=30
# ARK_LLM_MAX_TOKENS=512
# ARK_LLM_TEMPERATURE=0.0
# ARK_LLM_BASE_URL=http://192.168.50.2:8080
# ARK_DISTANCE_THRESHOLD=0.5

# --- LLM Pi ---
# ARK_ROLE=llm
# ARK_LLAMA_HOST=0.0.0.0
# ARK_LLAMA_PORT=8080
# ARK_MODEL_DIR=/srv/ark-pi/models
