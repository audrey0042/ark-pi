#!/bin/sh
# Fake git for install.sh tests. Set ARK_INSTALL_LOCAL_REPO to a source tree.

die() {
  echo "fake-git: $*" >&2
  exit 1
}

log_command() {
  if [ -n "${ARK_PI_INSTALL_COMMAND_LOG:-}" ]; then
    echo "git $*" >> "$ARK_PI_INSTALL_COMMAND_LOG"
  fi
}

sync_worktree_from_origin() {
  _worktree="$1"
  _source="${ARK_INSTALL_LOCAL_REPO}"
  if [ -z "$_source" ] || [ ! -d "$_source" ]; then
    die "ARK_INSTALL_LOCAL_REPO is not set"
  fi
  find "$_worktree" -mindepth 1 -maxdepth 1 ! -name '.git' -exec rm -rf {} +
  cp -a "$_source/." "$_worktree/"
  rm -rf "$_worktree/.venv"
}

if [ "$1" = "clone" ]; then
  log_command "$@"
  shift
  while [ $# -gt 0 ]; do
    case "$1" in
      --branch)
        shift 2
        ;;
      --)
        shift
        break
        ;;
      -*)
        die "unsupported clone flag: $1"
        ;;
      *)
        break
        ;;
    esac
  done
  if [ $# -lt 2 ]; then
    die "clone requires repo and destination"
  fi
  _repo="$1"
  _dest="$2"
  _source="${ARK_INSTALL_LOCAL_REPO}"
  case "$_dest" in
    *llama.cpp*)
      if [ -n "${ARK_INSTALL_LOCAL_LLAMA_REPO:-}" ]; then
        _source="$ARK_INSTALL_LOCAL_LLAMA_REPO"
      fi
      ;;
  esac
  if [ -z "$_source" ]; then
    die "ARK_INSTALL_LOCAL_REPO is not set"
  fi
  if [ ! -d "$_source" ]; then
    die "local repo is missing: $_source"
  fi
  mkdir -p "$_dest"
  cp -a "$_source/." "$_dest/"
  rm -rf "$_dest/.venv"
  rm -rf "$_dest/.git"
  mkdir -p "$_dest/.git"
  exit 0
fi

if [ "$1" = "-C" ]; then
  shift
  _worktree="$1"
  shift
  log_command -C "$_worktree" "$@"
  case "$1" in
    fetch)
      exit 0
      ;;
    checkout)
      exit 0
      ;;
    merge)
      shift
      if [ "$1" = "--ff-only" ]; then
        shift
        _remote_ref="$1"
        if [ "${ARK_INSTALL_GIT_DIVERGED:-0}" = "1" ]; then
          die "merge --ff-only failed (test hook: diverged history)"
        fi
        if [ "${ARK_INSTALL_GIT_BEHIND:-0}" = "1" ]; then
          sync_worktree_from_origin "$_worktree"
        fi
        exit 0
      fi
      die "unsupported git merge invocation: merge $*"
      ;;
    status)
      shift
      if [ "$1" = "--porcelain" ] && [ "${ARK_INSTALL_GIT_DIRTY:-0}" = "1" ]; then
        echo " M dirty.txt"
      fi
      exit 0
      ;;
    rev-parse)
      shift
      if [ "$1" = "--is-inside-work-tree" ]; then
        echo true
      fi
      exit 0
      ;;
    show-ref)
      shift
      if [ "$1" = "--verify" ] && [ "$2" = "--quiet" ]; then
        _ref="$3"
        case "$_ref" in
          refs/remotes/origin/main|refs/remotes/origin/master)
            exit 0
            ;;
        esac
        if [ -n "${ARK_INSTALL_GIT_REMOTE_BRANCH:-}" ]; then
          if [ "$_ref" = "refs/remotes/origin/$ARK_INSTALL_GIT_REMOTE_BRANCH" ]; then
            exit 0
          fi
        fi
        exit 1
      fi
      die "unsupported git show-ref invocation: show-ref $*"
      ;;
    *)
      die "unsupported git -C command: $1"
      ;;
  esac
fi

die "unsupported git invocation: $*"
