#!/bin/sh
# Fake apt-get for install.sh tests. Set ARK_PI_INSTALL_COMMAND_LOG to record calls.

if [ -n "${ARK_PI_INSTALL_COMMAND_LOG:-}" ]; then
  echo "apt-get $*" >> "$ARK_PI_INSTALL_COMMAND_LOG"
fi

case "$1" in
  update)
    if [ "${ARK_PI_INSTALL_APT_FAIL:-0}" = "1" ]; then
      echo "fake apt-get: update failed" >&2
      exit 1
    fi
    exit 0
    ;;
  install)
    if [ "${ARK_PI_INSTALL_APT_FAIL:-0}" = "1" ]; then
      echo "fake apt-get: install failed" >&2
      exit 1
    fi
    exit 0
    ;;
  *)
    exit 0
    ;;
esac
