#!/bin/sh
# Fake python3 for install.sh tests.

if [ "$1" = "-m" ] && [ "$2" = "venv" ]; then
  shift 2
  if [ "$1" = "--help" ]; then
    exit 0
  fi
  _venv="$1"
  if [ -z "$_venv" ]; then
    echo "fake-python3: missing venv path" >&2
    exit 1
  fi
  mkdir -p "$_venv/bin"
  cat > "$_venv/bin/pip" <<'EOF'
#!/bin/sh
if [ "$1" = "install" ] && [ "$2" = "-e" ]; then
  if [ -n "${ARK_PI_INSTALL_COMMAND_LOG:-}" ]; then
    echo "pip install -e $3" >> "$ARK_PI_INSTALL_COMMAND_LOG"
  fi
  touch "$(dirname "$0")/../.ark_installed"
  exit 0
fi
exit 0
EOF
  chmod +x "$_venv/bin/pip"
  cat > "$_venv/bin/ark" <<'EOF'
#!/bin/sh
log_cmd() {
  if [ -n "${ARK_PI_INSTALL_COMMAND_LOG:-}" ]; then
    _env_snapshot=$(env | grep '^ARK_' | sort | tr '\n' ' ')
    echo "ark $* env:${_env_snapshot}" >> "$ARK_PI_INSTALL_COMMAND_LOG"
  fi
}
if [ "$1" = "--help" ]; then
  log_cmd "$@"
  echo "fake ark help"
  exit 0
fi
if [ "$1" = "preflight" ]; then
  log_cmd "$@"
  if [ "${ARK_INSTALL_PREFLIGHT_FAIL:-0}" = "1" ]; then
    echo "fake preflight failed" >&2
    exit 1
  fi
  exit 0
fi
if [ "$1" = "llm" ] && [ "$2" = "status" ]; then
  log_cmd "$@"
  if [ "${ARK_INSTALL_LLM_STATUS_FAIL:-0}" = "1" ]; then
    echo "fake llm status failed" >&2
    exit 1
  fi
  exit 0
fi
if [ "$1" = "deploy" ] && [ "$2" = "preflight" ]; then
  log_cmd "$@"
  if [ "${ARK_INSTALL_PREFLIGHT_FAIL:-0}" = "1" ]; then
    echo "fake preflight failed" >&2
    exit 1
  fi
  exit 0
fi
if [ "$1" = "deploy" ] && [ "$2" = "render" ]; then
  if [ "${ARK_INSTALL_RENDER_FAIL:-0}" = "1" ]; then
    echo "fake render failed" >&2
    exit 1
  fi
  _output=""
  _role=""
  _prefix="/opt/ark-pi"
  _llama_bin="/srv/ark-pi/vendor/llama.cpp/build/bin/llama-server"
  _model_dir="/srv/ark-pi/models"
  _model_path="/srv/ark-pi/models/model.gguf"
  shift 2
  while [ $# -gt 0 ]; do
    case "$1" in
      --output-dir=*)
        _output="${1#*=}"
        shift
        ;;
      --output-dir)
        _output="$2"
        shift 2
        ;;
      --role=*)
        _role="${1#*=}"
        shift
        ;;
      --role)
        _role="$2"
        shift 2
        ;;
      --prefix=*)
        _prefix="${1#*=}"
        shift
        ;;
      --prefix)
        _prefix="$2"
        shift 2
        ;;
      --llama-bin=*)
        _llama_bin="${1#*=}"
        shift
        ;;
      --llama-bin)
        _llama_bin="$2"
        shift 2
        ;;
      --model-dir=*)
        _model_dir="${1#*=}"
        shift
        ;;
      --model-dir)
        _model_dir="$2"
        shift 2
        ;;
      --model-path=*)
        _model_path="${1#*=}"
        shift
        ;;
      --model-path)
        _model_path="$2"
        shift 2
        ;;
      --force)
        shift
        ;;
      *)
        shift
        ;;
    esac
  done
  if [ -n "${ARK_INSTALL_RENDER_LOG:-}" ]; then
    echo "deploy render --output-dir $_output --role $_role --force" >> "$ARK_INSTALL_RENDER_LOG"
  fi
  if [ -n "$_output" ]; then
    mkdir -p "$_output"
    touch "$_output/.rendered"
    if [ "${ARK_INSTALL_RENDER_SKIP_TEMPLATES:-0}" != "1" ]; then
      echo "ARK_ROLE=rag" > "$_output/ark-rag.env"
      echo "ARK_WORKSPACE_DIR=/generated/rag/workspace" >> "$_output/ark-rag.env"
      echo "[Service]" > "$_output/ark-rag.service"
      echo "ARK_ROLE=llm" > "$_output/ark-llm.env"
      echo "ARK_LLAMA_HOST=0.0.0.0" >> "$_output/ark-llm.env"
      echo "ARK_LLAMA_PORT=8080" >> "$_output/ark-llm.env"
      echo "ARK_MODEL_DIR=$_model_dir" >> "$_output/ark-llm.env"
      echo "ARK_MODEL_PATH=$_model_path" >> "$_output/ark-llm.env"
      echo "ARK_CONTEXT_SIZE=4096" >> "$_output/ark-llm.env"
      echo "ARK_THREADS=4" >> "$_output/ark-llm.env"
      echo "ARK_LLAMA_BIN=$_llama_bin" >> "$_output/ark-llm.env"
      {
        echo "[Service]"
        echo "EnvironmentFile=/etc/ark-pi/ark-llm.env"
        echo "WorkingDirectory=$_prefix"
        echo "ExecStart=\${ARK_LLAMA_BIN} --host \${ARK_LLAMA_HOST} --port \${ARK_LLAMA_PORT} --model \${ARK_MODEL_PATH} --ctx-size \${ARK_CONTEXT_SIZE} --threads \${ARK_THREADS}"
      } > "$_output/ark-llm.service"
    fi
  fi
  exit 0
fi
exit 0
EOF
  chmod +x "$_venv/bin/ark"
  exit 0
fi

if [ "$1" = "--version" ]; then
  echo "Python 3.12.0"
  exit 0
fi

exit 0
